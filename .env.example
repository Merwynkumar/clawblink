# ClawBlink -- No-Code AI Agent Builder from Chat

# Telegram bot token from @BotFather (required)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# === LLM Provider (pick ONE) ===

# Option 1: Ollama (DEFAULT -- local, free, no API key)
# Install from https://ollama.ai, then: ollama pull qwen2.5-coder:7b
OLLAMA_MODEL=qwen2.5-coder:7b
# Optional: seconds to wait for Ollama (default 180). Increase only if needed.
# OLLAMA_TIMEOUT=180

# Option 2: Gemini (free tier, rate limited)
# Get key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=your-gemini-key

# Option 3: Any OpenAI-compatible API (OpenAI, DeepSeek, Groq, Together, OpenRouter, Mistral)
# OPENAI_API_KEY=your-api-key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini
#
# Examples for other providers:
#   DeepSeek:   OPENAI_BASE_URL=https://api.deepseek.com/v1      OPENAI_MODEL=deepseek-chat
#   Groq:       OPENAI_BASE_URL=https://api.groq.com/openai/v1   OPENAI_MODEL=llama-3.3-70b-versatile
#   Together:   OPENAI_BASE_URL=https://api.together.xyz/v1      OPENAI_MODEL=meta-llama/Llama-3-70b-chat-hf
#   OpenRouter: OPENAI_BASE_URL=https://openrouter.ai/api/v1     OPENAI_MODEL=anthropic/claude-3.5-sonnet

#
# WhatsApp Web bridge uses your logged-in WhatsApp Web session in a local browser
# via the Node gateway in bridge/whatsapp/. No extra .env config is required for it.

# Optional: for agents that use football-data.org (e.g. EPL updates)
# Get a free key at https://www.football-data.org/
# FOOTBALL_DATA_ORG_API_KEY=your-api-key
